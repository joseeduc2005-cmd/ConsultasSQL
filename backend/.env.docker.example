PORT=3002
NODE_ENV=production
JWT_SECRET=change-this-secret-in-production
JWT_EXPIRE=7d

# Archivo de configuración multi-DB con hostnames de Docker
MULTI_DB_CONFIG_FILE=./config/multidb.databases.docker.json

# Ollama apunta al servicio docker "ollama"
OLLAMA_URL=http://ollama:11434/api/generate
OLLAMA_MODEL=deepseek-coder
OLLAMA_TIMEOUT_MS=5000

FORCE_DISTRIBUTED_MULTI_ENTITY=true
DEBUG_QUERY_ENGINE=false

CORS_ALLOWED_ORIGINS=http://localhost:3000
API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX=200
MAX_API_ROWS=100
SQL_QUERY_TIMEOUT_MS=10000
