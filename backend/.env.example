PORT=3001
NODE_ENV=development
JWT_SECRET=your-secret-key-here-change-in-production
JWT_EXPIRE=7d

# Multi-base
# Registrar multiples bases por archivo JSON es lo recomendado.
# La base principal del backend tambien debe vivir ahi con primary=true.
# Si no se define, el backend intentara leer ./config/multidb.databases.json.
MULTI_DB_CONFIG_FILE=./config/multidb.databases.json
# Fallback legacy opcional solo para compatibilidad temporal:
# DATABASE_URL=postgresql://user:password@localhost:5432/boton_pago
# Alternativa legacy: JSON inline en una sola linea
# MULTI_DB_CONFIG={"databases":[]}

# Fuerza que /api/query use resolucion distribuida cuando detecta consultas multi-entidad
FORCE_DISTRIBUTED_MULTI_ENTITY=true

# Debug / metricas tecnicas del motor de consulta
DEBUG_QUERY_ENGINE=false

# Seguridad API
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002
API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX=100
MAX_API_ROWS=100
SQL_QUERY_TIMEOUT_MS=8000
