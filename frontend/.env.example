# Environment Configuration Example
# ========================================

# Database Configuration
# Format: postgresql://username:password@host:port/database
# Example: postgresql://postgres:mypassword@localhost:5432/knowledge_base
DATABASE_URL=postgresql://postgres:password@localhost:5432/knowledge_base

# JWT Secret for Token Generation
# IMPORTANT: Change this in production to a long, random string
# Generate with: openssl rand -base64 32
JWT_SECRET=your_super_secret_key_change_in_production_12345

# Environment
# Values: development, production, testing
NODE_ENV=development

# Optional: Server Port (default: 3000)
PORT=3000

# Optional: Log Level
# Values: error, warn, info, debug
LOG_LEVEL=info

# Backend API URL used by Next.js API routes/proxies
NEXT_PUBLIC_BACKEND_URL=http://localhost:3002
